@page
@model TourRecommenderPlatform.Pages.Admin.Countries.IndexModel

@{
  ViewData["Title"] = "Керування країнами";
}

<div class="mb-4 d-flex justify-content-between align-items-start">
  <div>
    <h1 class="mb-1">Керування країнами</h1>
    <p class="text-muted mb-0">
      Довідник країн використовується для групування готелів і туристичних путівок за напрямами.
    </p>
  </div>

  <a asp-page="Create" class="btn btn-primary">
    Додати країну
  </a>
</div>

@if (TempData["SuccessMessage"] != null) {
  <div class="alert alert-success alert-dismissible fade show" role="alert">
    @TempData["SuccessMessage"]
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Закрити"></button>
  </div>
}

@if (TempData["ErrorMessage"] != null) {
  <div class="alert alert-danger alert-dismissible fade show" role="alert">
    @TempData["ErrorMessage"]
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Закрити"></button>
  </div>
}

<div class="card border-0 shadow-sm">
  <div class="card-header bg-white d-flex justify-content-between align-items-center">
    <h2 class="h5 mb-0">Список країн</h2>
    <span class="badge bg-primary">Кількість: @Model.Countries.Count</span>
  </div>

  <div class="card-body p-0">
    @if (!Model.Countries.Any()) {
      <div class="p-4 text-muted">
        Країни ще не додані.
      </div>
    } else {
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Назва</th>
              <th>Опис</th>
              <th>Готелі</th>
              <th>Тури</th>
              <th class="text-end">Дії</th>
            </tr>
          </thead>
          <tbody>
            @foreach (var country in Model.Countries) {
              <tr>
                <td class="fw-semibold">@country.Name</td>
                <td>
                  @if (string.IsNullOrWhiteSpace(country.Description)) {
                    <span class="text-muted">Опис не вказано</span>
                  } else {
                    @(country.Description.Length > 120
                                  ? country.Description.Substring(0, 120) + "..."
                                  : country.Description)
                            }
                </td>
                <td>
                  <span class="badge bg-secondary">@country.Hotels.Count</span>
                </td>
                <td>
                  <span class="badge bg-secondary">@country.Tours.Count</span>
                </td>
                <td class="text-end">
                  <a asp-page="Edit" asp-route-id="@country.Id" class="btn btn-sm btn-outline-primary">
                    Редагувати
                  </a>
                  <a asp-page="Delete" asp-route-id="@country.Id" class="btn btn-sm btn-outline-danger">
                    Видалити
                  </a>
                </td>
              </tr>
            }
          </tbody>
        </table>
      </div>
    }
  </div>
</div>