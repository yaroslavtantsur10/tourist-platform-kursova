@page
@model TourRecommenderPlatform.Pages.Admin.Tours.IndexModel

@{
  ViewData["Title"] = "Керування турами";
}

<div class="mb-4 d-flex justify-content-between align-items-start">
  <div>
    <h1 class="mb-1">Керування турами</h1>
    <p class="text-muted mb-0">
      Адміністратор може створювати, редагувати, деактивувати або видаляти туристичні путівки.
    </p>
  </div>

  <a asp-page="Create" class="btn btn-primary">
    Додати тур
  </a>
</div>

@if (TempData["SuccessMessage"] != null) {
  <div class="alert alert-success alert-dismissible fade show" role="alert">
    @TempData["SuccessMessage"]
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Закрити"></button>
  </div>
}

@if (TempData["ErrorMessage"] != null) {
  <div class="alert alert-danger alert-dismissible fade show" role="alert">
    @TempData["ErrorMessage"]
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Закрити"></button>
  </div>
}

<div class="card border-0 shadow-sm">
  <div class="card-header bg-white d-flex justify-content-between align-items-center">
    <h2 class="h5 mb-0">Список туристичних путівок</h2>
    <span class="badge bg-primary">Кількість: @Model.Tours.Count</span>
  </div>

  <div class="card-body p-0">
    @if (!Model.Tours.Any()) {
      <div class="p-4 text-muted">
        Тури ще не додані.
      </div>
    } else {
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Фото</th>
              <th>Назва</th>
              <th>Країна</th>
              <th>Готель</th>
              <th>Ціна</th>
              <th>Дати</th>
              <th>Місця</th>
              <th>Статус</th>
              <th>Зв’язки</th>
              <th class="text-end">Дії</th>
            </tr>
          </thead>
          <tbody>
            @foreach (var tour in Model.Tours) {
              <tr>
                <td style="width: 90px;">
                  @if (!string.IsNullOrWhiteSpace(tour.PhotoPath)) {
                    <img src="@tour.PhotoPath"
                         alt="@tour.Title"
                         class="rounded"
                         style="width: 72px; height: 52px; object-fit: cover;" />
                  } else {
                    <div class="bg-light border rounded d-flex align-items-center justify-content-center"
                         style="width: 72px; height: 52px;">
                      <span class="small text-muted">Фото</span>
                    </div>
                  }
                </td>

                <td class="fw-semibold">@tour.Title</td>

                <td>@(tour.Country?.Name ?? "Не вказано")</td>

                <td>@(tour.Hotel?.Name ?? "Не вказано")</td>

                <td>@tour.Price.ToString("N2") грн</td>

                <td>
                  <div>@tour.StartDate.ToString("dd.MM.yyyy")</div>
                  <div class="small text-muted">@tour.EndDate.ToString("dd.MM.yyyy")</div>
                </td>

                <td>@tour.AvailablePlaces</td>

                <td>
                  @if (tour.IsActive) {
                    <span class="badge bg-success">Активний</span>
                  } else {
                    <span class="badge bg-secondary">Деактивований</span>
                  }
                </td>

                <td>
                  <div class="small">Бронювання: @tour.Bookings.Count</div>
                  <div class="small">Відгуки: @tour.Reviews.Count</div>
                  <div class="small">Улюблені: @tour.FavoriteTours.Count</div>
                </td>

                <td class="text-end">
                  <a asp-page="Edit" asp-route-id="@tour.Id" class="btn btn-sm btn-outline-primary">
                    Редагувати
                  </a>

                  <a asp-page="Delete" asp-route-id="@tour.Id" class="btn btn-sm btn-outline-danger">
                    Видалити
                  </a>
                </td>
              </tr>
            }
          </tbody>
        </table>
      </div>
    }
  </div>
</div>