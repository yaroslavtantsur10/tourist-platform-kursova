@page
@model TourRecommenderPlatform.Pages.Admin.Reviews.IndexModel

@{
  ViewData["Title"] = "Перегляд відгуків";
}

<div class="mb-4">
  <h1 class="mb-1">Перегляд відгуків</h1>
  <p class="text-muted mb-0">
    На цій сторінці адміністратор може переглядати оцінки та коментарі користувачів,
    які також використовуються як навчальні дані для рекомендаційної моделі.
  </p>
</div>

@if (!string.IsNullOrWhiteSpace(Model.SuccessMessage)) {
  <div class="alert alert-success alert-dismissible fade show" role="alert">
    @Model.SuccessMessage
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Закрити"></button>
  </div>
}

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage)) {
  <div class="alert alert-danger alert-dismissible fade show" role="alert">
    @Model.ErrorMessage
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Закрити"></button>
  </div>
}

<div class="card border-0 shadow-sm">
  <div class="card-header bg-white d-flex justify-content-between align-items-center">
    <h2 class="h5 mb-0">Усі відгуки</h2>
    <span class="badge bg-primary">Кількість: @Model.Reviews.Count</span>
  </div>

  <div class="card-body p-0">
    @if (!Model.Reviews.Any()) {
      <div class="p-4 text-muted">
        Відгуки ще не додані.
      </div>
    } else {
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Користувач</th>
              <th>Тур</th>
              <th>Напрям</th>
              <th>Оцінка</th>
              <th>Коментар</th>
              <th>Дата</th>
              <th class="text-end">Дії</th>
            </tr>
          </thead>
          <tbody>
            @foreach (var review in Model.Reviews) {
              <tr>
                <td>
                  <div class="fw-semibold">
                    @(review.User?.FullName ?? "Ім’я не вказано")
                  </div>
                  <div class="small text-muted">
                    @(review.User?.Email ?? "Email не вказано")
                  </div>
                </td>

                <td>
                  @if (review.Tour != null) {
                    <div class="fw-semibold">@review.Tour.Title</div>
                    <div class="small text-muted">@review.Tour.Price.ToString("N2") грн</div>
                  } else {
                    <span class="text-muted">Тур не знайдено</span>
                  }
                </td>

                <td>
                  <div>@(review.Tour?.Country?.Name ?? "Країна не вказана")</div>
                  <div class="small text-muted">
                    @(review.Tour?.Hotel?.Name ?? "Готель не вказаний")
                  </div>
                </td>

                <td>
                  <span class="badge bg-warning text-dark">
                    @review.Rating ★
                  </span>
                </td>

                <td style="max-width: 320px;">
                  @if (string.IsNullOrWhiteSpace(review.Comment)) {
                    <span class="text-muted">Без текстового коментаря</span>
                  } else {
                    @(review.Comment.Length > 160
                                  ? review.Comment.Substring(0, 160) + "..."
                                  : review.Comment)
                            }
                </td>

                <td>@review.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>

                <td class="text-end">
                  <form method="post" asp-page-handler="Delete" asp-route-id="@review.Id" class="d-inline">
                    <button type="submit"
                            class="btn btn-sm btn-outline-danger"
                            onclick="return confirm('Видалити цей відгук?');">
                      Видалити
                    </button>
                  </form>
                </td>
              </tr>
            }
          </tbody>
        </table>
      </div>
    }
  </div>
</div>