@page "{id:int}"
@model TourRecommenderPlatform.Pages.Tours.DetailsModel

@{
  ViewData["Title"] = Model.Tour.Title;
}

<div class="mb-3">
  <a asp-page="/Tours/Index" class="btn btn-outline-secondary">
    ← Повернутися до каталогу
  </a>
</div>

@if (TempData["SuccessMessage"] != null) {
  <div class="alert alert-success alert-dismissible fade show" role="alert">
    @TempData["SuccessMessage"]
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Закрити"></button>
  </div>
}

@if (TempData["ErrorMessage"] != null) {
  <div class="alert alert-danger alert-dismissible fade show" role="alert">
    @TempData["ErrorMessage"]
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Закрити"></button>
  </div>
}

<div class="row g-4">
  <div class="col-lg-6">
    @if (!string.IsNullOrWhiteSpace(Model.Tour.PhotoPath)) {
      <img src="@Model.Tour.PhotoPath"
           alt="@Model.Tour.Title"
           class="img-fluid rounded shadow-sm w-100"
           style="max-height: 430px; object-fit: cover;" />
    } else {
      <div class="bg-light border rounded d-flex align-items-center justify-content-center"
           style="height: 360px;">
        <span class="text-muted">Фото туру відсутнє</span>
      </div>
    }
  </div>

  <div class="col-lg-6">
    <h1 class="mb-3">@Model.Tour.Title</h1>

    <div class="mb-3">
      @if (Model.Tour.AvailablePlaces > 0) {
        <span class="badge bg-success">Є доступні місця</span>
      } else {
        <span class="badge bg-danger">Місць немає</span>
      }

      @if (Model.AverageRating > 0) {
        <span class="badge bg-warning text-dark">
          Середня оцінка: @Model.AverageRating.ToString("F1")
        </span>
      } else {
        <span class="badge bg-secondary">
          Оцінок ще немає
        </span>
      }
    </div>

    <dl class="row">
      <dt class="col-sm-4">Країна</dt>
      <dd class="col-sm-8">@(Model.Tour.Country?.Name ?? "Не вказано")</dd>

      <dt class="col-sm-4">Готель</dt>
      <dd class="col-sm-8">
        @(Model.Tour.Hotel?.Name ?? "Не вказано")
        @if (Model.Tour.Hotel != null) {
          <span class="text-muted">(@Model.Tour.Hotel.Rating★)</span>
        }
      </dd>

      <dt class="col-sm-4">Ціна</dt>
      <dd class="col-sm-8 fw-semibold">@Model.Tour.Price.ToString("N2") грн</dd>

      <dt class="col-sm-4">Дата початку</dt>
      <dd class="col-sm-8">@Model.Tour.StartDate.ToString("dd.MM.yyyy")</dd>

      <dt class="col-sm-4">Дата завершення</dt>
      <dd class="col-sm-8">@Model.Tour.EndDate.ToString("dd.MM.yyyy")</dd>

      <dt class="col-sm-4">Доступні місця</dt>
      <dd class="col-sm-8">@Model.Tour.AvailablePlaces</dd>

      <dt class="col-sm-4">Кількість відгуків</dt>
      <dd class="col-sm-8">@Model.ReviewsCount</dd>
    </dl>

    <div class="d-flex gap-2 mt-4">
      @if (User.Identity?.IsAuthenticated == true) {
        <form method="post" asp-page="/Favorites/Index" asp-page-handler="Add" asp-route-tourId="@Model.Tour.Id">
          <button type="submit" class="btn btn-outline-danger">
            Додати до улюблених
          </button>
        </form>

        <form method="post" asp-page="/Bookings/Index" asp-page-handler="Create" asp-route-tourId="@Model.Tour.Id">
          <button type="submit" class="btn btn-primary" disabled="@(Model.Tour.AvailablePlaces <= 0)">
            Забронювати
          </button>
        </form>
      } else {
        <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-primary">
          Увійти для бронювання
        </a>
      }
    </div>
  </div>
</div>

<div class="mt-5">
  <h2 class="h4">Опис туру</h2>
  <p>@Model.Tour.Description</p>
</div>

<div class="mt-5">
  <h2 class="h4">Відгуки та оцінки</h2>

  @if (!Model.Tour.Reviews.Any()) {
    <div class="alert alert-info">
      Для цього туру ще немає відгуків. Після авторизації користувач зможе залишити оцінку та коментар.
    </div>
  } else {
    <div class="row g-3">
      @foreach (var review in Model.Tour.Reviews.OrderByDescending(r => r.CreatedAt)) {
        <div class="col-md-6">
          <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
              <div class="d-flex justify-content-between mb-2">
                <strong>@(review.User?.FullName ?? review.User?.Email ?? "Користувач")</strong>
                <span class="badge bg-warning text-dark">@review.Rating ★</span>
              </div>

              <div class="small text-muted mb-2">
                @review.CreatedAt.ToString("dd.MM.yyyy HH:mm")
              </div>

                @if (!string.IsNullOrWhiteSpace(review.Comment))
                {
                    <p class="mb-0">@review.Comment</p>
                }
            </div>
          </div>
        </div>
      }
    </div>
  }
</div>

@if (User.Identity?.IsAuthenticated == true)
{
    <div class="mt-5">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white">
                <h2 class="h5 mb-0">
                    @(Model.CurrentUserHasReview ? "Редагувати власний відгук" : "Залишити оцінку та відгук")
                </h2>
            </div>

            <div class="card-body">
                @if (Model.CurrentUserHasReview)
                {
                    <div class="alert alert-info">
                        Ви вже залишали відгук для цього туру. Повторне надсилання форми оновить попередню оцінку та коментар.
                    </div>
                }

                <form method="post" asp-page-handler="Review" asp-route-id="@Model.Tour.Id">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="ReviewInput.Rating" class="form-label"></label>
                        <select asp-for="ReviewInput.Rating" class="form-select">
                            <option value="1">1 — дуже низька оцінка</option>
                            <option value="2">2 — низька оцінка</option>
                            <option value="3">3 — середня оцінка</option>
                            <option value="4">4 — висока оцінка</option>
                            <option value="5">5 — відмінна оцінка</option>
                        </select>
                        <span asp-validation-for="ReviewInput.Rating" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ReviewInput.Comment" class="form-label"></label>
                        <textarea asp-for="ReviewInput.Comment" class="form-control" rows="4"
                                  placeholder="За бажанням опишіть свої враження від туру"></textarea>
                        <span asp-validation-for="ReviewInput.Comment" class="text-danger"></span>
                        <div class="form-text">
                            Текстовий коментар не є обов’язковим.
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary">
                        @(Model.CurrentUserHasReview ? "Оновити відгук" : "Додати відгук")
                    </button>
                </form>
            </div>
        </div>
    </div>
}
else
{
    <div class="mt-5">
        <div class="alert alert-secondary">
            Щоб залишити оцінку та відгук, потрібно
            <a asp-area="Identity" asp-page="/Account/Login" class="alert-link">увійти до системи</a>.
        </div>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}