@using Microsoft.AspNetCore.Identity
@using TourRecommenderPlatform.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav">
  @if (SignInManager.IsSignedIn(User)) {
    var currentUser = await UserManager.GetUserAsync(User);
    var displayName = currentUser?.FullName ?? User.Identity?.Name ?? "Користувач";

    <li class="nav-item">
      <span class="nav-link text-dark">Вітаємо, @displayName!</span>
    </li>
    <li class="nav-item">
      <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout"
            asp-route-returnUrl="@Url.Page("/Index", new { area = "" })" method="post">
        <button type="submit" class="nav-link btn btn-link text-dark">
          Вийти
        </button>
      </form>
    </li>
  } else {
    <li class="nav-item">
      <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Register">
        Реєстрація
      </a>
    </li>
    <li class="nav-item">
      <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Login">
        Вхід
      </a>
    </li>
  }
</ul>