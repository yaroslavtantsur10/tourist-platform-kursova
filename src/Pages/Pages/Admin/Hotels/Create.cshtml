@page
@model TourRecommenderPlatform.Pages.Admin.Hotels.CreateModel

@{
  ViewData["Title"] = "Додавання готелю";
}

<div class="mb-4">
  <h1 class="mb-1">Додавання готелю</h1>
  <p class="text-muted mb-0">
    Заповніть основні відомості про готель і виберіть країну, до якої він належить.
  </p>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-body">
    <form method="post">
      <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

      <div class="mb-3">
        <label asp-for="Hotel.Name" class="form-label">Назва готелю</label>
        <input asp-for="Hotel.Name" class="form-control" />
        <span asp-validation-for="Hotel.Name" class="text-danger"></span>
      </div>

      <div class="mb-3">
        <label asp-for="Hotel.CountryId" class="form-label">Країна</label>
        <select asp-for="Hotel.CountryId" asp-items="Model.CountriesSelectList" class="form-select">
          <option value="">-- Оберіть країну --</option>
        </select>
        <span asp-validation-for="Hotel.CountryId" class="text-danger"></span>
      </div>

      <div class="mb-3">
        <label asp-for="Hotel.Rating" class="form-label">Рейтинг готелю</label>
        <select asp-for="Hotel.Rating" class="form-select">
          <option value="">-- Оберіть рейтинг --</option>
          <option value="1">1 зірка</option>
          <option value="2">2 зірки</option>
          <option value="3">3 зірки</option>
          <option value="4">4 зірки</option>
          <option value="5">5 зірок</option>
        </select>
        <span asp-validation-for="Hotel.Rating" class="text-danger"></span>
      </div>

      <div class="mb-3">
        <label asp-for="Hotel.Description" class="form-label">Опис</label>
        <textarea asp-for="Hotel.Description" class="form-control" rows="5"></textarea>
        <span asp-validation-for="Hotel.Description" class="text-danger"></span>
      </div>

      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">
          Зберегти
        </button>

        <a asp-page="Index" class="btn btn-outline-secondary">
          Скасувати
        </a>
      </div>
    </form>
  </div>
</div>

@section Scripts {
  <partial name="_ValidationScriptsPartial" />
}