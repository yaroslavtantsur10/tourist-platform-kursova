@page "{id:int}"
@model TourRecommenderPlatform.Pages.Admin.Tours.DeleteModel

@{
  ViewData["Title"] = "Видалення або деактивація туру";
}

<div class="mb-4">
  <h1 class="mb-1">Видалення або деактивація туру</h1>
  <p class="text-muted mb-0">
    Якщо тур має пов’язані бронювання, відгуки або записи в улюбленому, його потрібно деактивувати,
    а не видаляти фізично.
  </p>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-body">
    <div class="row g-4">
      <div class="col-md-4">
        @if (!string.IsNullOrWhiteSpace(Model.Tour.PhotoPath)) {
          <img src="@Model.Tour.PhotoPath"
               alt="@Model.Tour.Title"
               class="img-fluid rounded border" />
        } else {
          <div class="bg-light border rounded d-flex align-items-center justify-content-center"
               style="height: 220px;">
            <span class="text-muted">Фото відсутнє</span>
          </div>
        }
      </div>

      <div class="col-md-8">
        <h2 class="h4">@Model.Tour.Title</h2>

        <dl class="row">
          <dt class="col-sm-4">Країна</dt>
          <dd class="col-sm-8">@(Model.Tour.Country?.Name ?? "Не вказано")</dd>

          <dt class="col-sm-4">Готель</dt>
          <dd class="col-sm-8">@(Model.Tour.Hotel?.Name ?? "Не вказано")</dd>

          <dt class="col-sm-4">Ціна</dt>
          <dd class="col-sm-8">@Model.Tour.Price.ToString("N2") грн</dd>

          <dt class="col-sm-4">Період</dt>
          <dd class="col-sm-8">
            @Model.Tour.StartDate.ToString("dd.MM.yyyy") —
            @Model.Tour.EndDate.ToString("dd.MM.yyyy")
          </dd>

          <dt class="col-sm-4">Доступні місця</dt>
          <dd class="col-sm-8">@Model.Tour.AvailablePlaces</dd>

          <dt class="col-sm-4">Статус</dt>
          <dd class="col-sm-8">
            @if (Model.Tour.IsActive) {
              <span class="badge bg-success">Активний</span>
            } else {
              <span class="badge bg-secondary">Деактивований</span>
            }
          </dd>

          <dt class="col-sm-4">Бронювання</dt>
          <dd class="col-sm-8">@Model.BookingsCount</dd>

          <dt class="col-sm-4">Відгуки</dt>
          <dd class="col-sm-8">@Model.ReviewsCount</dd>

          <dt class="col-sm-4">Улюблені записи</dt>
          <dd class="col-sm-8">@Model.FavoritesCount</dd>
        </dl>
      </div>
    </div>

    <hr />

    @if (Model.HasRelatedData) {
      <div class="alert alert-warning">
        Цей тур має пов’язані дані, тому його не можна фізично видалити без порушення цілісності системи.
        Рекомендована дія — деактивація туру.
      </div>

      <form method="post" asp-page-handler="Deactivate" asp-route-id="@Model.Tour.Id" class="d-inline">
        <button type="submit" class="btn btn-warning" disabled="@(!Model.Tour.IsActive)">
          Деактивувати тур
        </button>
      </form>

      <a asp-page="Index" class="btn btn-outline-secondary">
        Скасувати
      </a>
    } else {
      <div class="alert alert-danger">
        Тур не має пов’язаних бронювань, відгуків або улюблених записів. Його можна фізично видалити.
      </div>

      <form method="post" asp-page-handler="Delete" asp-route-id="@Model.Tour.Id" class="d-inline">
        <button type="submit" class="btn btn-danger">
          Видалити фізично
        </button>
      </form>

      <a asp-page="Index" class="btn btn-outline-secondary">
        Скасувати
      </a>
    }
  </div>
</div>