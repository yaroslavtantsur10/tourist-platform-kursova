@page "{id:int}"
@model TourRecommenderPlatform.Pages.Admin.Tours.EditModel

@{
  ViewData["Title"] = "Редагування туру";
}

<div class="mb-4">
  <h1 class="mb-1">Редагування туру</h1>
  <p class="text-muted mb-0">
    Оновіть інформацію про туристичну путівку, її активність або фото.
  </p>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-body">
    <form method="post" enctype="multipart/form-data">
      <input type="hidden" asp-for="Input.Id" />
      <input type="hidden" asp-for="Input.ExistingPhotoPath" />

      <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

      @if (!string.IsNullOrWhiteSpace(Model.Input.ExistingPhotoPath)) {
        <div class="mb-3">
          <label class="form-label">Поточне фото</label>
          <div>
            <img src="@Model.Input.ExistingPhotoPath"
                 alt="@Model.Input.Title"
                 class="rounded border"
                 style="max-width: 260px; height: 160px; object-fit: cover;" />
          </div>
        </div>
      }

      <div class="row">
        <div class="col-md-8 mb-3">
          <label asp-for="Input.Title" class="form-label"></label>
          <input asp-for="Input.Title" class="form-control" />
          <span asp-validation-for="Input.Title" class="text-danger"></span>
        </div>

        <div class="col-md-4 mb-3">
          <label asp-for="Input.Price" class="form-label"></label>
          <input asp-for="Input.Price"
                 class="form-control"
                 type="text"
                 inputmode="decimal"
                 autocomplete="off"
                 value="@Model.Input.Price.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)" />
          <span asp-validation-for="Input.Price" class="text-danger"></span>
        </div>

      <div class="mb-3">
        <label asp-for="Input.Description" class="form-label"></label>
        <textarea asp-for="Input.Description" class="form-control" rows="5"></textarea>
        <span asp-validation-for="Input.Description" class="text-danger"></span>
      </div>

      <div class="row">
        <div class="col-md-6 mb-3">
          <label asp-for="Input.CountryId" class="form-label"></label>
          <select asp-for="Input.CountryId" asp-items="Model.CountriesSelectList" class="form-select">
            <option value="">-- Оберіть країну --</option>
          </select>
          <span asp-validation-for="Input.CountryId" class="text-danger"></span>
        </div>

        <div class="col-md-6 mb-3">
          <label asp-for="Input.HotelId" class="form-label"></label>
          <select asp-for="Input.HotelId" asp-items="Model.HotelsSelectList" class="form-select">
            <option value="">-- Оберіть готель --</option>
          </select>
          <span asp-validation-for="Input.HotelId" class="text-danger"></span>
        </div>
      </div>

      <div class="row">
        <div class="col-md-4 mb-3">
          <label asp-for="Input.StartDate" class="form-label"></label>
          <input asp-for="Input.StartDate" class="form-control" />
          <span asp-validation-for="Input.StartDate" class="text-danger"></span>
        </div>

        <div class="col-md-4 mb-3">
          <label asp-for="Input.EndDate" class="form-label"></label>
          <input asp-for="Input.EndDate" class="form-control" />
          <span asp-validation-for="Input.EndDate" class="text-danger"></span>
        </div>

        <div class="col-md-4 mb-3">
          <label asp-for="Input.AvailablePlaces" class="form-label"></label>
          <input asp-for="Input.AvailablePlaces" class="form-control" />
          <span asp-validation-for="Input.AvailablePlaces" class="text-danger"></span>
        </div>
      </div>

      <div class="mb-3">
        <label asp-for="Input.PhotoFile" class="form-label"></label>
        <input asp-for="Input.PhotoFile" class="form-control" type="file" accept=".jpg,.jpeg,.png,.webp" />
        <span asp-validation-for="Input.PhotoFile" class="text-danger"></span>
        <div class="form-text">
          Якщо нове фото не обрано, поточне зображення залишиться без змін.
        </div>
      </div>

      <div class="form-check mb-4">
        <input asp-for="Input.IsActive" class="form-check-input" />
        <label asp-for="Input.IsActive" class="form-check-label"></label>
      </div>

      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">
          Зберегти зміни
        </button>

        <a asp-page="Index" class="btn btn-outline-secondary">
          Скасувати
        </a>
      </div>
    </form>
  </div>
</div>

@section Scripts {
  <partial name="_ValidationScriptsPartial" />

  <script>
    const priceInput = document.querySelector('[name="Input.Price"]');

    if (priceInput) {
      priceInput.addEventListener('input', function () {
        this.value = this.value.replace(',', '.');
      });
    }

    $.validator.methods.number = function (value, element) {
      return this.optional(element) || /^-?\d+(\.\d+)?$/.test(value);
    };
  </script>
}