@page
@model TourRecommenderPlatform.Pages.Admin.Users.IndexModel

@{
  ViewData["Title"] = "Керування користувачами";
}

<div class="mb-4">
  <h1 class="mb-1">Керування користувачами</h1>
  <p class="text-muted mb-0">
    Сторінка призначена для перегляду зареєстрованих користувачів, контролю їхнього статусу
    та виконання адміністративного блокування або розблокування облікових записів.
  </p>
</div>

<div class="mt-3">
  <a asp-page="/Admin/Dashboard/Index" class="btn btn-outline-secondary">
    ← Повернутися до дашборда
  </a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.SuccessMessage)) {
  <div class="alert alert-success alert-dismissible fade show" role="alert">
    @Model.SuccessMessage
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Закрити"></button>
  </div>
}

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage)) {
  <div class="alert alert-danger alert-dismissible fade show" role="alert">
    @Model.ErrorMessage
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Закрити"></button>
  </div>
}

<div class="card border-0 shadow-sm">
  <div class="card-header bg-white d-flex justify-content-between align-items-center">
    <h2 class="h5 mb-0">Список користувачів</h2>
    <span class="badge bg-primary">
      Кількість: @Model.UsersList.Count
    </span>
  </div>

  <div class="card-body p-0">
    @if (!Model.UsersList.Any()) {
      <div class="p-4 text-muted">
        Користувачів поки не знайдено.
      </div>
    } else {
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>ПІБ</th>
              <th>Email</th>
              <th>Ролі</th>
              <th>Дата реєстрації</th>
              <th>Статус</th>
              <th class="text-end">Дії</th>
            </tr>
          </thead>
          <tbody>
            @foreach (var user in Model.UsersList) {
              <tr>
                <td>
                  <div class="fw-semibold">
                    @(string.IsNullOrWhiteSpace(user.FullName) ? "Не вказано" : user.FullName)
                  </div>

                  @if (user.IsCurrentUser) {
                    <div class="small text-muted">
                      Поточний обліковий запис
                    </div>
                  }
                </td>

                <td>@user.Email</td>

                <td>
                  <span class="badge bg-secondary">
                    @user.Roles
                  </span>
                </td>

                <td>@user.RegisteredAt.ToString("dd.MM.yyyy HH:mm")</td>

                <td>
                  @if (user.IsBlocked) {
                    <span class="badge bg-danger">Заблокований</span>
                  } else {
                    <span class="badge bg-success">Активний</span>
                  }
                </td>

                <td class="text-end">
                  @if (user.IsBlocked) {
                    <form method="post" asp-page-handler="Unblock" asp-route-id="@user.Id" class="d-inline">
                      <button type="submit" class="btn btn-sm btn-outline-success">
                        Розблокувати
                      </button>
                    </form>
                  } else {
                    <form method="post" asp-page-handler="Block" asp-route-id="@user.Id" class="d-inline">
                      <button type="submit"
                              class="btn btn-sm btn-outline-danger"
                              disabled="@user.IsCurrentUser"
                              onclick="return confirm('Заблокувати цього користувача?');">
                        Заблокувати
                      </button>
                    </form>
                  }
                </td>
              </tr>
            }
          </tbody>
        </table>
      </div>
    }
  </div>
</div>